         <div type="abstract">
            <head>Abstract:</head>
            <p><persName>Calixt III.</persName> übersendet dem <persName>Erzbischof Balduin von Bremen</persName> das Pallium.<list>
                  <item>[Listeneintrag 1]</item>
               </list></p>
         </div>

